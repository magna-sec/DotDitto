# DotDitto — gitignore

# Session data (contains sensitive credential hashes — never commit)
session.json
session.json.tmp
sessions/

# Python virtual environment
venv/
.venv/
env/
.env/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# IDE / editor
.vscode/
.claude/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Hashcat pot files (contain cracked credentials — keep local only)
*.pot
*.potfile
